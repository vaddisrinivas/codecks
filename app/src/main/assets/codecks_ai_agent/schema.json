{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codecks AI Creator V2 Envelope",
  "description": "The app supplies a stricter proposal schema for the requested artifact kind at runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "message", "questions", "assumptions", "proposal"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "status": {
      "type": "string",
      "enum": ["ready", "needs_input", "unsupported", "refused"]
    },
    "message": { "type": "string" },
    "questions": {
      "type": "array",
      "maxItems": 4,
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string" }
    },
    "proposal": {
      "description": "Null unless status is ready. Runtime schema defines the exact typed proposal.",
      "type": ["object", "null"]
    }
  }
}
