{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codecks.local/protocol/codex-cockpit/snapshot.schema.json",
  "title": "Codecks Codex Cockpit Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAt",
    "source",
    "privacy",
    "tasks"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "description": "ISO-8601 timestamp generated by the Mac-side bridge."
    },
    "source": {
      "type": "string",
      "description": "Bridge source, for example connector, local-metadata, github, or mock."
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promptContentIncluded",
        "sourceContentIncluded"
      ],
      "properties": {
        "promptContentIncluded": {
          "type": "boolean",
          "const": false
        },
        "sourceContentIncluded": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "repoPath",
          "branch",
          "state",
          "elapsedLabel",
          "updatedLabel",
          "needsAttention",
          "hasUnread",
          "safeSummary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "repoPath": {
            "type": "string"
          },
          "branch": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "Idle",
              "Queued",
              "Running",
              "NeedsAttention",
              "Blocked",
              "Succeeded",
              "Failed",
              "Released",
              "Offline"
            ]
          },
          "elapsedLabel": {
            "type": "string"
          },
          "updatedLabel": {
            "type": "string"
          },
          "needsAttention": {
            "type": "boolean"
          },
          "hasUnread": {
            "type": "boolean"
          },
          "effortMode": {
            "type": "string",
            "enum": [
              "Fast",
              "Standard",
              "Deep",
              "Unknown"
            ]
          },
          "safeSummary": {
            "type": "string",
            "description": "Short sanitized status summary. Must not include prompt or source code by default."
          }
        }
      }
    }
  }
}

