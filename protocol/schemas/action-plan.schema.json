{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codecks.local/protocol/schemas/action-plan.schema.json",
  "title": "Codecks Action Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "createdAt",
    "steps"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "planId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{8,80}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stepId",
          "actionId",
          "arguments"
        ],
        "properties": {
          "stepId": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]{1,80}$"
          },
          "actionId": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+)+$"
          },
          "arguments": {
            "type": "object",
            "additionalProperties": true
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
